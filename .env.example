# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com  # Used for sitemap generation (defaults to buildvoiceai.com)

# Stripe (Platform billing — multi-tier)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Self-Service plan prices (monthly + yearly)
STRIPE_PRICE_SELF_SERVICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_SELF_SERVICE_STARTER_YEARLY=price_...
STRIPE_PRICE_SELF_SERVICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_SELF_SERVICE_GROWTH_YEARLY=price_...
STRIPE_PRICE_SELF_SERVICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_SELF_SERVICE_AGENCY_YEARLY=price_...

# Managed plan prices (monthly + yearly)
STRIPE_PRICE_MANAGED_STARTER_MONTHLY=price_...
STRIPE_PRICE_MANAGED_STARTER_YEARLY=price_...
STRIPE_PRICE_MANAGED_GROWTH_MONTHLY=price_...
STRIPE_PRICE_MANAGED_GROWTH_YEARLY=price_...
STRIPE_PRICE_MANAGED_AGENCY_MONTHLY=price_...
STRIPE_PRICE_MANAGED_AGENCY_YEARLY=price_...

# Metered per-minute billing price ($0.15/min — shared across all tiers)
STRIPE_PRICE_METERED_MINUTE=price_...

# Platform API Keys (used as fallback when agency doesn't have their own — triggers per-minute billing)
# PLATFORM_RETELL_API_KEY=your_platform_retell_key
# PLATFORM_VAPI_API_KEY=your_platform_vapi_key
# PLATFORM_BLAND_API_KEY=your_platform_bland_key
# PLATFORM_ELEVENLABS_API_KEY=your_platform_elevenlabs_key

# Legacy price IDs (backward compat for existing subscriptions — optional)
# STRIPE_PRICE_ID_STARTER=price_...
# STRIPE_PRICE_ID_GROWTH=price_...
# STRIPE_PRICE_ID_SCALE=price_...

# Stripe Connect (agency → client billing, separate webhook endpoint)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# Cron Job Security
CRON_SECRET=your_random_32_char_secret

# Redis (optional - falls back to in-memory rate limiting if not configured)
# Supports redis:// and rediss:// (TLS) URLs
# Examples:
#   Local: redis://localhost:6379
#   With password: redis://:password@localhost:6379
#   TLS (Upstash, etc): rediss://default:password@hostname:6379
REDIS_URL=

# Voice AI Providers (set per-agency in Settings, not globally required)
# RETELL_API_KEY=your_retell_api_key
# VAPI_API_KEY=your_vapi_api_key

# CRM Integrations (OAuth - configure in respective developer portals)
# GHL_CLIENT_ID=your_ghl_client_id
# GHL_CLIENT_SECRET=your_ghl_client_secret
# GHL_REDIRECT_URI=https://your-domain.com/api/auth/crm/callback
# GHL_APP_SSO_KEY=your_ghl_sso_key (from GHL portal > Advanced Settings > Auth)
# HUBSPOT_CLIENT_ID=your_hubspot_client_id
# HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret
# HUBSPOT_REDIRECT_URI=https://your-domain.com/api/auth/hubspot/callback

# Slack Integration (OAuth - configure at api.slack.com/apps)
# SLACK_CLIENT_ID=your_slack_client_id
# SLACK_CLIENT_SECRET=your_slack_client_secret
# SLACK_REDIRECT_URI=https://your-domain.com/api/auth/slack/callback

# Calendly Integration (OAuth - configure at developer.calendly.com)
# CALENDLY_CLIENT_ID=your_calendly_client_id
# CALENDLY_CLIENT_SECRET=your_calendly_client_secret
# CALENDLY_REDIRECT_URI=https://your-domain.com/api/auth/calendly/callback

# Google Calendar Integration (OAuth - configure in Google Cloud Console)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google-calendar/callback

# Live Call API (used by book-appointment endpoint during active calls)
LIVE_CALL_API_SECRET=your_random_secret

# AI Agent Builder (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...

# SMS (Twilio) - for Send SMS workflow action
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# Email (Resend) - for Send Email workflow action
# RESEND_API_KEY=re_xxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# Feedback notification email (defaults to support@buildvoiceai.com if not set)
# FEEDBACK_NOTIFY_EMAIL=support@yourdomain.com

# Platform Admin (comma-separated email allowlist for /admin and impersonation)
# ADMIN_EMAILS=admin@buildvoiceai.com

# Encryption key for API keys at rest (AES-256-GCM, any length — SHA-256 hashed internally)
# Generate with: openssl rand -hex 32
# ⚠️ REQUIRED IN PRODUCTION — API keys are stored encrypted
# ENCRYPTION_KEY=your-secret-encryption-key-here

# Auth Settings
# Set to "true" to skip email verification on signup (development only)
# ⚠️ DO NOT SET IN PRODUCTION — users will bypass email verification
# SKIP_EMAIL_VERIFICATION=true

# Trial period for new agency signups (default: 7 days)
# TRIAL_DAYS=7

# Beta trial promo code (case-insensitive) and fixed end date (YYYY-MM-DD)
# When a user enters this code at signup, they get full Agency-tier access until the end date
# BETA_PROMO_CODE=your_beta_code
# BETA_TRIAL_END_DATE=2026-04-30

# Custom Domain Configuration
# PLATFORM_HOSTNAME — domain that custom domains CNAME to (default: buildvoiceai.com)
# VERCEL_PROJECT_DOMAIN — your Vercel project domain for CNAME validation (e.g., my-project.vercel.app)

# Vercel API (required for custom domain management)
# VERCEL_TOKEN — Vercel API token (Settings → Tokens)
# VERCEL_PROJECT_ID — project ID (Settings → General → Project ID)
# VERCEL_TEAM_ID — team/org ID (optional, for team projects)

# Error Monitoring (Sentry)
# Run: npx @sentry/wizard@latest -i nextjs
# Then set the DSN from your Sentry project:
# SENTRY_DSN=https://your-sentry-dsn
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

